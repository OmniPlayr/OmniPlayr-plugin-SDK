{
  "name": "@omniplayr/plugins",
  "version": "1.1.0",
  "description": "Frontend plugin SDK for OmniPlayr plugins.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmniPlayr/OmniPlayr-plugin-SDK.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/OmniPlayr/OmniPlayr-plugin-SDK/issues"
  },
  "homepage": "https://omniplayr.wokki20.nl/",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build":  "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json",
    "typecheck":  "node ./node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.9.3"
  },
  "sideEffects": false
}
